.LSOverride
._*

# Agent sessions (keep structure, ignore content)
.agents/SESSIONS/*.md
!.agents/SESSIONS/.gitkeep
.agents/TASKS/*.md
!.agents/TASKS/.gitkeep

# Agent memory: commit project memory at the root, ignore machine-specific
# (personal) memory written by the scan-and-memorize skill.
.agents/memory/local/*
!.agents/memory/local/.gitkeep

# Skill discovery mirrors are regenerable symlinks (scripts/skills.sh sync).
# Source of truth is .agents/skills/. Keep the dir, ignore the links.
.claude/skills/*
!.claude/skills/.gitkeep
.codex/skills/*
!.codex/skills/.gitkeep

# Logs
*.log
logs/

# Build artifacts
dist/
*.app
*.ipa
*.dSYM.zip
*.dSYM
MacSweep/.build/

# Headless snapshot output (regenerable via scripts/render-screenshots.sh)
scripts/screenshots/*
!scripts/screenshots/02-assistant.png
!scripts/screenshots/26-system-junk-results.png
!scripts/screenshots/27-large-old-files-results.png

# gpt-image logo generation scratch
.codex_logos/
